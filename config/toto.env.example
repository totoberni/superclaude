# toto connection config. Copy to config/toto.env (gitignored) and fill in.
# TOTO_TAILSCALE_IP: toto's Tailscale IP (find it with: tailscale ip -4 on toto).
#                    It is a CGNAT 100.64.0.0/10 address, reachable only inside your tailnet.
# NTFY_PORT:         the port the self-hosted ntfy server listens on.
TOTO_TAILSCALE_IP=100.64.0.0
NTFY_PORT=2586

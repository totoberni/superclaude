# ~/.claude/superclaude.env — superclaude v3 environment for the `claude` process.
#
# These vars must be in the ENVIRONMENT when the Claude Code binary starts (the
# auto-memory block + offline-embed flags are read at startup). Keep them OUT of
# ~/.bashrc (no global-shell pollution): a scoped `claude` wrapper sources this file
# only when launching claude. See the wrapper snippet below / in claude-shortcuts.sh.
#
# Activation (recommended — add to ~/.claude/scripts/claude-shortcuts.sh, already
# sourced from ~/.bashrc, so zero new bashrc lines):
#
#     claude() {
#         [ -f "$HOME/.claude/superclaude.env" ] && . "$HOME/.claude/superclaude.env"
#         command claude "$@"
#     }
#
# (`command claude` calls the real binary, not the wrapper. Scoped to terminal launches.)

# --- FastEmbed / memory+comms DB: use the locally-cached model, never hit network ---
export HF_HUB_OFFLINE=1
export TRANSFORMERS_OFFLINE=1

# --- Top-level memory block: REPLACE the binary's hardcoded "# Persistent Agent
#     Memory" (MD-file) instructions with DB-based ones. NOTE: this reaches
#     TOP-LEVEL agents only (claude --agent X). Subagents do NOT get this block —
#     they are handled by the memory-inject SubagentStart hook + rules + CLAUDE.md. ---
export CLAUDE_COWORK_MEMORY_GUIDELINES="Your persistent memory is a hybrid-search SQLite DB at ~/.claude/agent-memory/.memory.db (NOT MD files; there is no MEMORY.md to read). To recall, run: HF_HUB_OFFLINE=1 ~/.claude/.venv/bin/python ~/.claude/scripts/memory/memory_db.py search \"<query>\" -k 8 then get --name <slug>. Query the DB proactively whenever a task touches a project, library, tool, or past decision. Memory is tiered (instance/<agent>, shared-projects, shared-global, class) and typed (feedback/project/reference/user). To write/update memory use the memory skills (/remember, /good-idea, /lt-mem, /mistake) — never hand-write .md memory files. Comms history: comms_db.py search."

# --- ALTERNATIVE (mutually exclusive with the line above): instead of REPLACING the
#     block, DISABLE auto-memory entirely and rely on the memory-inject SessionStart
#     hook + rules for top-level memory. Uncomment to use this approach instead:
# export CLAUDE_CODE_DISABLE_AUTO_MEMORY=1

# === Operational state (project-specific, not framework) ===

# Project-orch comms (users create their own per-project)
comms/o-*/
comms/orch-*/
comms/_archive/

# Meta memory (cross-project operational context)
# Covers both legacy flat path and v2 matrix path
agent-memory/meta/
agent-memory/instance/meta/

# Auto-generated snapshots and archives (both symlink and actual paths)
agent-memory/_compact-snapshots/
agent-memory/_archive/
agent-memory/_system/_compact-snapshots/
agent-memory/_system/_archive/

# Project-orch instance memory (both legacy flat and v2 matrix paths)
agent-memory/o-*/
agent-memory/orch-*/
agent-memory/instance/o-*/
agent-memory/instance/orch-*/

# Project-specific shared knowledge (keep only superclaude.md)
agent-memory/shared/projects/*
!agent-memory/shared/projects/superclaude.md

# Plans (project-specific orchestration)
plans/

# === Round-2 sensitivity purge (M-2026-05-06 audit) ===

# Agent memory — entire tree. Per-orch / class / instance / shared all
# accumulate private project context over time. Forkers bootstrap a fresh
# memory tree on first use. (Supersedes the granular agent-memory/* rules
# above; those become redundant subsets.)
agent-memory/

# Comms — every per-agent subdirectory holds runtime state for a specific
# orch / skill / class. Only the README.md format spec at the top level
# stays tracked. (Supersedes comms/o-*/, comms/orch-*/, comms/_archive/.)
comms/*/

# Personal config files — modifying them in-tree breaks the active
# superclaude install. Live files are gitignored; *.example counterparts
# (which forkers copy + customise) are tracked.
CLAUDE.md
settings.json

# Hook local config — contains personal project names; gitignored so the
# .example counterpart is the publishable template.
hooks/no-commit-projects.local

# Live meta registry — accumulates project names and orch operational state;
# gitignored so meta-registry.md.example is the publishable template.
comms/meta-registry.md

# Named-orch aliases at top of agents/ — each names a private project
agents/o-*.md
agents/orch-*.md
agents/_archive/

# Misc runtime / cache state
usage-limits.json
mcp-needs-auth-cache.json

# Python bytecode
__pycache__/
*.pyc

# SQLite DB files (memory, comms, broker — regenerated at runtime)
*.db
*.db-wal
*.db-shm

# LaTeX warn cache (rebuilt per-session)
.latex-warn-cache/

# Local override directory (machine-specific, never publish)
/local

# === v3 runtime / venv / cache clutter (2026-06-07) ===
.venv/
.cache/
_backups/
.debug-*
/.context-latest.json
/.rate-latest.json
/.cost-cache.json
/.cost-ledger.json
/.nb-progress.json

# === v3 daemon/jobs/notebook + comms-log + bak runtime (2026-06-07 commit hygiene) ===
# Daemon supervisor runtime (roster/lock/log/status regenerated each launch)
daemon/
daemon.lock
daemon.log
daemon.status.json
# Job-queue + notebook operational state (project-specific; /notebook/ holds private project scaffolds)
jobs/
/notebook/
# One-shot update result + comms runtime logs (top-level; comms/*/ only covers subdirs)
.last-update-result.json
comms/_*.log
# settings.json backups (broadens the exact settings.json.bak rule to catch -suffix variants)
settings.json.bak*
# settings.local.json backups (local override may carry machine-specific config — never publish)
settings.local.json.bak*

# === Secrets env files — PUBLIC repo, never commit (.env.example stubs ARE committable) ===
# Generalizes the original scripts/telegram-surface/.env rule (superclaude-v4 F3);
# also covers services/firecrawl/.env (DIR-002 T2) and any future service .env.
**/.env
config/*.env

# === Cockpit live scripts — peer-host-specific; .example counterparts are tracked ===
scripts/cockpit/cockpit.bash
scripts/cockpit/cockpit.fish
bin/tsudo
bin/tsh
.last-cleanup

# daemon auth runtime state (repo root, 2026-07-11)
daemon-auth-cooldown
daemon-auth-status.json

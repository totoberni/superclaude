#!/usr/bin/env bash
# tsh.example — TEMPLATE for the remote-exec shortcut (agent-forwarded ssh, no sudo).
#
# ADOPTION NOTES:
#   1. Copy this file to bin/tsh (tsh is gitignored; only this .example ships in the public repo).
#   2. Replace PEERHOST with your ~/.ssh/config host alias, PEERNAME with the peer's hostname,
#      and KEYFILE with your private key path.
#   3. No args opens an interactive session; on the peer itself the command runs locally.
#   4. tsh does NOT need the forwarded agent: if it's dead, tsh falls back to a plain (no-agent)
#      ssh using PEERHOST's own IdentityFile (configure `IdentityFile KEYFILE` for PEERHOST in
#      your ~/.ssh/config). Remote sudo inside the command will not authenticate in that
#      fallback case.
#   5. Transient connect failures (timeout/refused/unreachable) are retried up to 3x with 2s/4s
#      backoff; a clean non-zero exit from the REMOTE command is never retried.
set -euo pipefail

if [ "$(hostname)" = "PEERNAME" ]; then
  [ $# -eq 0 ] && exec "$SHELL"
  exec "$@"
fi

SOCK="$HOME/.ssh/agent.sock"
AGENT_OK=1
{ [ -S "$SOCK" ] && SSH_AUTH_SOCK="$SOCK" ssh-add -l >/dev/null 2>&1; } || AGENT_OK=0

if [ "$AGENT_OK" -eq 0 ]; then
  echo "tsh: agent not ready, falling back to plain ssh (no agent forwarding; remote sudo will not work). Fix: rm -f $SOCK; ssh-agent -a $SOCK; SSH_AUTH_SOCK=$SOCK ssh-add KEYFILE" >&2
fi

if [ $# -eq 0 ]; then
  if [ "$AGENT_OK" -eq 1 ]; then
    exec env SSH_AUTH_SOCK="$SOCK" ssh -A PEERHOST
  else
    exec env -u SSH_AUTH_SOCK ssh PEERHOST
  fi
fi

TRANSIENT_RE='Connection (timed out|refused)|Network is unreachable|No route to host|Operation timed out|Could not resolve hostname'
err_file="$(mktemp)"
trap 'rm -f "$err_file"' EXIT

attempt=1
max_attempts=3
delay=2
rc=0
set +e
while true; do
  if [ "$AGENT_OK" -eq 1 ]; then
    timeout "${TSH_TIMEOUT:-300}" env SSH_AUTH_SOCK="$SOCK" ssh -A PEERHOST "$*" 2>"$err_file"
  else
    timeout "${TSH_TIMEOUT:-300}" env -u SSH_AUTH_SOCK ssh PEERHOST "$*" 2>"$err_file"
  fi
  rc=$?
  cat "$err_file" >&2
  if [ "$rc" -eq 255 ] && grep -qE "$TRANSIENT_RE" "$err_file" && [ "$attempt" -lt "$max_attempts" ]; then
    echo "tsh: transient connect failure (attempt $attempt/$max_attempts), retrying in ${delay}s..." >&2
    sleep "$delay"
    delay=$((delay * 2))
    attempt=$((attempt + 1))
    continue
  fi
  break
done
set -e
exit "$rc"

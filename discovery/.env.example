# NordVPN WireGuard/NordLynx key for gluetun (discovery egress, D3).
# Copy this file to .env (chmod 600) and fill in. .env is never committed or synced.
#
# HOW TO GET THE KEY (one-time):
#   1. my.nordaccount.com -> NordVPN -> scroll to "Advanced Settings (Manual setup)"
#      -> "Set up NordVPN manually" -> enter the emailed verification code.
#   2. Click "Generate new token" (choose 30-day) and copy the ACCESS TOKEN.
#   3. Extract the static WireGuard key with that token (run on toto or hand the
#      token to meta):
#        curl -s -u token:<ACCESS_TOKEN> \
#          https://api.nordvpn.com/v1/users/services/credentials | jq -r .nordlynx_private_key
#   4. Paste the resulting base64 key below. The access token can then be revoked;
#      only this key persists.
WIREGUARD_PRIVATE_KEY=
# Optional egress country (default Netherlands). Never a single server hostname.
SERVER_COUNTRIES=Netherlands

# --- OpenVPN fallback (only if a NordLynx key is ever rejected) ---
# From the same page, "Service credentials" tab (NOT your account email/password):
# NORD_SVC_USER=
# NORD_SVC_PASS=

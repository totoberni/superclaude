#!/usr/bin/env bash
# /notebook skill — CLI entry point.
# All subcommands route through nb_main.py via the skill's bundled Python.
# Project venv is required: skill imports nbformat / jupytext / nbclient / nbdime / pylatexenc / psutil.

set -euo pipefail

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PYTHONPATH="${SKILL_DIR}:${PYTHONPATH:-}"

# Resolve interpreter: project-local .venv > shell python3
PYTHON_BIN=""
if [[ -n "${VIRTUAL_ENV:-}" && -x "${VIRTUAL_ENV}/bin/python" ]]; then
  PYTHON_BIN="${VIRTUAL_ENV}/bin/python"
elif [[ -n "${1:-}" && -d "${1}/.venv/bin" ]]; then
  PYTHON_BIN="${1}/.venv/bin/python"
else
  # Walk up from CWD looking for a .venv
  cur="$PWD"
  while [[ "$cur" != "/" ]]; do
    if [[ -x "$cur/.venv/bin/python" ]]; then
      PYTHON_BIN="$cur/.venv/bin/python"
      break
    fi
    cur="$(dirname "$cur")"
  done
fi
[[ -z "$PYTHON_BIN" ]] && PYTHON_BIN="python3"

exec "$PYTHON_BIN" "${SKILL_DIR}/nb_main.py" "$@"

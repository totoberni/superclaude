# Telegram factory surface — secrets stub.
# Copy to .env in this directory, fill in, then:  chmod 600 .env
# The real .env is gitignored and must NEVER be committed (~/.claude is a PUBLIC repo).

# Bot token from @BotFather (the bot stays OFF until this exists — HG-F3 gate).
TELEGRAM_BOT_TOKEN=

# Comma-separated numeric Telegram user IDs allowed to talk to the bot.
# Get yours from @userinfobot. Empty list = bot refuses to start (fail-closed).
ALLOWED_USER_IDS=

#!/usr/bin/env python3
"""hcom-status — quick inspection of HCOM broker state.

Replaces the shell version; uses Broker class as single SOT for DB access.
No sqlite3 CLI dependency — pure Python (stdlib only).
"""

import argparse
import json
import os
import sys
import time

# Allow `import hcom_broker` from sibling file (hcom-broker.py).
# Python module names cannot contain '-', so symlink/import-by-path:
_SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, _SCRIPT_DIR)
try:
    import importlib.util
    _spec = importlib.util.spec_from_file_location(
        "hcom_broker", os.path.join(_SCRIPT_DIR, "hcom-broker.py")
    )
    if _spec is None or _spec.loader is None:
        raise ImportError(f"cannot load hcom-broker.py from {_SCRIPT_DIR}")
    hcom_broker = importlib.util.module_from_spec(_spec)
    _spec.loader.exec_module(hcom_broker)
    Broker = hcom_broker.Broker
except (ImportError, FileNotFoundError) as e:
    print(f"Error: cannot import hcom_broker from {_SCRIPT_DIR}: {e}", file=sys.stderr)
    sys.exit(1)


def fmt_ts(ts):
    """Format unix epoch as readable timestamp."""
    if ts is None or ts == "":
        return "-"
    try:
        return time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(int(ts)))
    except (ValueError, TypeError):
        return str(ts)


def fmt_table(rows, headers):
    """Simple table formatter."""
    if not rows:
        return "(empty)"
    widths = [
        max(len(str(h)), max(len(str(r.get(h, ""))) for r in rows))
        for h in headers
    ]
    lines = []
    lines.append(" | ".join(str(h).ljust(w) for h, w in zip(headers, widths)))
    lines.append("-+-".join("-" * w for w in widths))
    for r in rows:
        lines.append(" | ".join(str(r.get(h, "")).ljust(w) for h, w in zip(headers, widths)))
    return "\n".join(lines)


def main():
    p = argparse.ArgumentParser(
        description="HCOM status — quick inspection of broker state"
    )
    p.add_argument(
        "mode",
        nargs="?",
        default="summary",
        choices=["summary", "json", "recent", "locks", "agents"],
        help="What to show (default: summary)",
    )
    p.add_argument("--limit", type=int, default=20, help="For 'recent' mode")
    a = p.parse_args()

    db_path = os.path.expanduser("~/.claude/comms/.broker.db")
    if not os.path.exists(db_path):
        print(f"HCOM DB not initialized: {db_path}")
        print("Run: ~/.claude/scripts/hcom-init.sh")
        sys.exit(1)

    try:
        b = Broker()
    except RuntimeError as e:
        print(f"Broker error: {e}", file=sys.stderr)
        sys.exit(1)

    if a.mode == "json":
        print(json.dumps(b.status(), indent=2))

    elif a.mode == "recent":
        msgs = b.recent_messages(limit=a.limit)
        if not msgs:
            print("(no messages)")
            return
        for m in msgs:
            m["time"] = fmt_ts(m.get("ts"))
            m["status"] = "unread" if m.get("read_at") is None else "read"
            m["body_preview"] = (m.get("body") or "")[:40]
            if m.get("seq") is None:
                m["seq"] = ""
        print(fmt_table(
            msgs,
            ["id", "time", "from_agent", "to_agent", "kind", "seq", "body_preview", "status"],
        ))

    elif a.mode == "locks":
        locks = b.active_locks()
        if not locks:
            print("(no active locks)")
            return
        now = int(time.time())
        for l in locks:
            l["since"] = fmt_ts(l.get("acquired_at"))
            try:
                l["remaining_sec"] = max(
                    0,
                    int(l.get("acquired_at", 0)) + int(l.get("ttl_sec", 0)) - now,
                )
            except (TypeError, ValueError):
                l["remaining_sec"] = "-"
        print(fmt_table(
            locks,
            ["path", "locked_by", "since", "ttl_sec", "remaining_sec"],
        ))

    elif a.mode == "agents":
        agents = b.agent_table()
        if not agents:
            print("(no agents tracked)")
            return
        for ag in agents:
            ag["started"] = fmt_ts(ag.get("started_at"))
            ag["last_active"] = fmt_ts(ag.get("last_active_at"))
        print(fmt_table(
            agents,
            ["agent", "pid", "started", "last_active", "state"],
        ))

    else:  # summary
        s = b.status()
        st = os.stat(db_path)
        print("## HCOM Status")
        print()
        print(f"DB: {db_path}")
        print(f"Size: {st.st_size} bytes | Modified: {fmt_ts(st.st_mtime)}")
        print()
        print(f"Messages: {s['messages_total']} total / {s['messages_unread']} unread")
        print(f"Agents tracked: {s['agents_tracked']}")
        print(f"Active file_locks: {s['active_locks']}")
        print()
        print("Inspect with:")
        print("  hcom-status recent    # last 20 messages")
        print("  hcom-status agents    # agent_status table")
        print("  hcom-status locks     # active file_locks")
        print("  hcom-status json      # raw JSON")


if __name__ == "__main__":
    main()
